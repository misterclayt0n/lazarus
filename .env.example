# Convex writes these during `bunx convex dev --once --configure new --project lazarus`.
PUBLIC_CONVEX_URL=
PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# WorkOS AuthKit. Configure these in Vercel and local .env.local.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:5173/callback
WORKOS_COOKIE_PASSWORD=
